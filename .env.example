# ── PostgreSQL (used by docker-compose) ───────
POSTGRES_DB=stockflow_db
POSTGRES_USER=stockflow
POSTGRES_PASSWORD=stockflow123

# ── FastAPI backend ────────────────────────────
DATABASE_URL=postgresql+asyncpg://stockflow:stockflow123@db:5432/stockflow_db
SECRET_KEY=your-super-secret-jwt-key-change-this-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS — set to your frontend domain in production ──
FRONTEND_URL=http://localhost:3000

# ── Vite frontend ──────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
